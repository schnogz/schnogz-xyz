{
  "name": "schnogz-xyz",
  "description": "Andrew Schneider's personal site built with Gatsby",
  "version": "1.1.0",
  "author": "Andrew Schneider",
  "license": "MIT",
  "scripts": {
    "clean": "gatsby clean",
    "ci:build": "gatsby build",
    "ci:lint": "eslint 'src/**/*.{js,ts,tsx}' --max-warnings=0",
    "dev": "gatsby develop",
    "format": "prettier --write 'src/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,ts,tsx}' --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/material": "9.1.1",
    "@n8tb1t/use-scroll-position": "4.0.0",
    "framer-motion": "12.40.0",
    "gatsby-plugin-preconnect": "1.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-github-calendar": "5.0.6",
    "react-icons": "5.6.0",
    "styled-components": "6.4.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "babel-plugin-styled-components": "2.3.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "3.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sort-destructure-keys": "3.0.0",
    "eslint-plugin-sort-keys-fix": "1.1.2",
    "gatsby": "5.16.1",
    "gatsby-plugin-google-analytics": "5.16.0",
    "gatsby-plugin-robots-txt": "1.8.0",
    "gatsby-plugin-root-import": "2.0.9",
    "gatsby-plugin-sitemap": "6.16.0",
    "gatsby-plugin-styled-components": "6.16.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "15.2.10",
    "prettier": "3.8.4",
    "typescript": "5.7.3"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx}": "eslint --max-warnings=0 --fix"
  },
  "resolutions": {
    "@types/react": "19.2.17",
    "browserslist": "4.24.0"
  },
  "packageManager": "yarn@4.17.0"
}
